# Copy file ini ke .env dan sesuaikan nilainya.
# open-meteo tidak butuh API key — tidak perlu diisi.

# Postgres credentials (harus sama dengan docker-compose.yml)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# AQI database URL — dipakai oleh src/ dan dashboard
AQI_DB_URL=postgresql://airflow:airflow@localhost/aqi_db

# MLflow tracking server
MLFLOW_TRACKING_URI=http://localhost:5000
